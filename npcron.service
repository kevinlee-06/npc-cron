[Unit]
Description=NPC-Cron Backend Service
After=network.target

[Service]
User=kevin
Group=kevin
WorkingDirectory=/home/kevin/npcron/backend
Environment="PYTHONPATH=/home/kevin/npcron/backend"
ExecStart=/home/kevin/npcron/.venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
